# ── OpenAI ────────────────────────────────────────────────────────────────────
# Required by: transcribe
# Get yours at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── Anthropic ─────────────────────────────────────────────────────────────────
# Required by: find-segment
# Get yours at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ── Diarization backend ───────────────────────────────────────────────────────
# Options: whisper-heuristic (default, no extra key needed)
#          assemblyai          (requires ASSEMBLYAI_API_KEY)
#          pyannote-local      (requires PYANNOTE_ENDPOINT)
DIARIZE_BACKEND=whisper-heuristic

# ── AssemblyAI (optional) ─────────────────────────────────────────────────────
# Required only when DIARIZE_BACKEND=assemblyai
# Get yours at https://www.assemblyai.com/dashboard
# ASSEMBLYAI_API_KEY=...

# ── pyannote local sidecar (optional) ────────────────────────────────────────
# Required only when DIARIZE_BACKEND=pyannote-local
# Run the sidecar: docker run -p 8000:8000 pyannote/speaker-diarization
# PYANNOTE_ENDPOINT=http://localhost:8000
