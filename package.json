{
  "name": "video-splitter",
  "version": "1.0.0",
  "description": "CLI tools for processing large MKV video files",
  "type": "module",
  "scripts": {
    "agent": "tsx src/agent.ts",
    "video-to-audio": "tsx src/commands/video-to-audio.ts",
    "audio-to-transcript": "tsx src/commands/audio-to-transcript.ts",
    "video-remove-silence": "tsx src/commands/video-remove-silence.ts",
    "transcript-find-segment": "tsx src/commands/transcript-find-segment.ts",
    "segment-render": "tsx src/commands/segment-render.ts",
    "transcript-to-distillation-plan": "tsx src/commands/transcript-to-distillation-plan.ts",
    "distillation-render": "tsx src/commands/distillation-render.ts",
    "transcript-to-topic": "tsx src/commands/transcript-to-topic.ts",
    "topic-to-compilation": "tsx src/commands/topic-to-compilation.ts",
    "compilation-refine": "tsx src/commands/compilation-refine.ts",
    "compilation-render": "tsx src/commands/compilation-render.ts",
    "topic-to-banner": "tsx src/commands/topic-to-banner.ts",
    "transcript-to-bleep-plan": "tsx src/commands/transcript-to-bleep-plan.ts",
    "video-apply-bleep": "tsx src/commands/video-apply-bleep.ts",
    "server": "tsx src/server.ts",
    "frontend": "npm --prefix frontend run dev",
    "dev": "concurrently -n server,frontend -c cyan,magenta \"npm run server\" \"npm run frontend\"",
    "help": "tsx src/commands/help.ts"
  },
  "bin": {
    "video-to-audio": "./src/commands/video-to-audio.ts",
    "audio-to-transcript": "./src/commands/audio-to-transcript.ts",
    "video-remove-silence": "./src/commands/video-remove-silence.ts",
    "transcript-find-segment": "./src/commands/transcript-find-segment.ts",
    "segment-render": "./src/commands/segment-render.ts",
    "transcript-to-distillation-plan": "./src/commands/transcript-to-distillation-plan.ts",
    "distillation-render": "./src/commands/distillation-render.ts",
    "transcript-to-topic": "./src/commands/transcript-to-topic.ts",
    "topic-to-compilation": "./src/commands/topic-to-compilation.ts",
    "compilation-refine": "./src/commands/compilation-refine.ts",
    "compilation-render": "./src/commands/compilation-render.ts",
    "topic-to-banner": "./src/commands/topic-to-banner.ts",
    "transcript-to-bleep-plan": "./src/commands/transcript-to-bleep-plan.ts",
    "video-apply-bleep": "./src/commands/video-apply-bleep.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.71.2",
    "@strands-agents/sdk": "^1.0.0-rc.3",
    "commander": "^12.1.0",
    "dotenv": "^17.4.2",
    "fluent-ffmpeg": "^2.1.3",
    "openai": "^6.7.0",
    "undici": "^7.25.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/node": "^22.14.0",
    "concurrently": "^9.2.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
